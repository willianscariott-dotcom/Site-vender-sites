---
import Button from './Button.astro';
---

<header class="fixed top-0 w-full z-50 border-b border-zinc-800/50 bg-black/80 backdrop-blur-xl">
  <div class="1px linear-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800 absolute bottom-0 left-0 w-full h-[1px]"></div>
  <div class="max-w-screen-2xl mx-auto px-6 h-16 flex items-center justify-between shadow-none">
    <a href="/" class="font-inter text-lg font-extrabold tracking-[-0.03em]">
      <span class="text-white">Anúncio</span><span class="text-[#6366F1]">e Site</span>
    </a>
    <div class="hidden md:flex">
      <Button variant="cta">
        Solicitar Análise de Conversão
      </Button>
    </div>
  </div>
</header>