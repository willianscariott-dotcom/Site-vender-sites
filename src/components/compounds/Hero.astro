---
import Button from '../Button.astro';
---

<section class="relative pt-32 pb-24 bg-transparent overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
    <!-- Coluna Esquerda - Textos -->
    <div class="text-center lg:text-left">
      <!-- Badge minimalista -->
      <div class="inline-flex items-center gap-2 text-xs text-emerald-500 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="font-medium">Nota Máxima no Google Pagespeed</span>
      </div>

      <!-- H1 -->
      <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-tight font-['Outfit']">
        O Site Que Transforma Seus Anúncios em <span class="text-[#6366F1]">Clientes no WhatsApp</span>.
      </h1>

      <!-- Subtítulo -->
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto lg:mx-0 mt-4 leading-relaxed">
        Nossa infraestrutura garante que nenhuma oportunidade seja perdida. Substituímos seu site lento por uma estrutura de alta performance focada em uma única coisa: fazer seu telefone tocar.
      </p>

      <!-- Trust Signal - Métrica de Impacto -->
      <div class="mt-8 flex flex-col sm:flex-row items-center lg:justify-start justify-center gap-2 sm:gap-4 bg-zinc-900/60 border border-zinc-800 rounded-md py-3 px-5 max-w-xl mx-auto lg:mx-0">
        <span class="font-mono text-2xl font-bold text-emerald-400 whitespace-nowrap">5 em 10</span>
        <span class="text-sm text-zinc-300 text-center sm:text-left">clientes são perdidos por sites lentos antes da página abrir <span class="text-zinc-500">(dados do Google)</span></span>
      </div>

      <!-- Botão CTA -->
      <div class="mt-10">
        <a href="#planos" class="inline-flex items-center justify-center text-base px-10 py-4 bg-[#6366F1] text-white font-semibold rounded-md hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all">
          Ver Planos
        </a>
      </div>
    </div>

    <!-- Coluna Direita - Card Premium com Barras -->
    <div class="relative w-full mt-8 lg:mt-0">
      <!-- Glow behind card -->
      <div class="absolute -inset-4 bg-indigo-500/10 blur-[80px] rounded-full pointer-events-none"></div>
      
      <div class="bg-[#111115]/80 backdrop-blur-xl border border-zinc-800/80 rounded-xl p-10 relative shadow-2xl">
        <h3 class="text-lg font-semibold text-white mb-6 text-center font-['Outfit']">Dashboard de Performance</h3>
        
        <div class="space-y-6 font-mono">
          <!-- Barra 1: Site Lento -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <span class="text-sm font-medium text-zinc-500">Site Padrão (LCP)</span>
              <span class="text-xs text-red-400 font-medium">4.5s</span>
            </div>
            <div class="h-2 bg-zinc-800/50 rounded-full overflow-hidden">
              <div class="h-full w-[85%] bg-zinc-700 rounded-full"></div>
            </div>
          </div>
          
          <!-- Barra 2: Anúncio e Site -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <span class="text-sm font-bold text-white">Anúncio e Site (LCP)</span>
              <span class="text-xs text-emerald-500 font-medium">< 1.2s</span>
            </div>
            <div class="h-2 bg-zinc-800/50 rounded-full overflow-hidden">
              <div class="h-full w-[20%] bg-[#6366F1] rounded-full shadow-[0_0_12px_rgba(99,102,241,0.6)]"></div>
            </div>
          </div>
        </div>

        <!-- Resultado -->
        <div class="mt-6 pt-6 border-t border-zinc-800 text-center">
          <p class="text-sm text-zinc-400">
            <span class="text-emerald-400 font-bold">100%</span> dos visitantes têm acesso instantâneo à sua página
          </p>
        </div>
      </div>
    </div>
  </div>
</section>