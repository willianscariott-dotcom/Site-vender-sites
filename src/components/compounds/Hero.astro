---
import Badge from '../Badge.astro';
import Button from '../Button.astro';
---

<section class="relative pt-20 pb-32 flex flex-col items-center text-center">
  <div class="absolute inset-0 engineering-grid -z-10 [mask-image:radial-gradient(ellipse_at_center,black,transparent_70%)]"></div>
  
  <div class="bg-zinc-950/80 backdrop-blur-md border border-slate-800 rounded-lg px-4 py-2 mb-8">
    <Badge variant="success" pulse={true}>
      LCP garantido &lt; 1.0s
    </Badge>
  </div>

  <h1 class="font-headline-h1 text-headline-h1 max-w-4xl mb-6">
    Páginas Ultrarrápidas que Dobram seu ROI no Google Ads.
  </h1>

  <p class="font-body-base text-body-base text-text-secondary max-w-2xl mb-10">
    Substitua seu WordPress lento por código puro em Astro. Reduza o custo por lead e venda mais.
  </p>

  <div class="flex gap-4">
    <Button variant="primary">Analisar Meu Site Atual</Button>
    <Button variant="secondary">Como Funciona</Button>
  </div>
</section>