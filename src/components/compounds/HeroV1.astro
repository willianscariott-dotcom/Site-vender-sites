---
// Opção 1 adaptada: dashboard em linguagem leiga (sem siglas técnicas)
---

<section class="relative pt-32 pb-24 bg-transparent overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">

    <!-- Coluna Esquerda (igual em todas as variantes) -->
    <div class="text-center lg:text-left">
      <div class="inline-flex items-center gap-2 text-xs text-emerald-500 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="font-medium">Nota Máxima no Google Pagespeed</span>
      </div>
      <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-tight font-['Outfit']">
        O Site Que Transforma Seus Anúncios em <span class="text-[#6366F1]">Clientes no WhatsApp</span>.
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto lg:mx-0 mt-4 leading-relaxed">
        Nossa infraestrutura garante que nenhuma oportunidade seja perdida. Substituímos seu site lento por uma estrutura de alta performance focada em uma única coisa: fazer seu telefone tocar.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center lg:justify-start justify-center gap-2 sm:gap-4 bg-zinc-900/60 border border-zinc-800 rounded-2xl py-3 px-5 max-w-xl mx-auto lg:mx-0">
        <span class="font-mono text-2xl font-bold text-emerald-400 whitespace-nowrap">5 em 10</span>
        <span class="text-sm text-zinc-300 text-center sm:text-left">clientes são perdidos por sites lentos antes da página abrir <span class="text-zinc-500">(dados do Google)</span></span>
      </div>
      <div class="mt-10">
        <a href="#planos" class="inline-flex items-center gap-2 text-base px-8 py-4 bg-[#6366F1] text-white font-semibold rounded-xl hover:bg-indigo-500 hover:shadow-[0_0_24px_rgba(99,102,241,0.4)] transition-all active:scale-[0.97]">
          Ver Planos
          <svg class="w-4 h-4" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <!-- Coluna Direita — VARIANTE 1: Painel de saúde em linguagem leiga -->
    <div class="relative w-full mt-8 lg:mt-0">
      <div class="absolute -inset-4 bg-indigo-500/10 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="bg-[#111115]/80 backdrop-blur-xl border border-zinc-800/80 rounded-3xl p-8 relative shadow-2xl">
        <!-- Header do card -->
        <div class="flex items-center justify-between mb-8">
          <h3 class="text-base font-semibold text-white font-['Outfit']">Diagnóstico de Performance</h3>
          <div class="flex items-center gap-1.5 text-xs text-emerald-500 font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            AO VIVO
          </div>
        </div>

        <!-- Score central -->
        <div class="flex items-center justify-center mb-8">
          <div class="relative w-32 h-32">
            <svg class="w-32 h-32 -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="50" fill="none" stroke="#27272a" stroke-width="10"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="#6366F1" stroke-width="10"
                stroke-dasharray="314" stroke-dashoffset="0" stroke-linecap="round"
                class="transition-all duration-1000"/>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="font-['Outfit'] text-4xl font-bold text-white">100</span>
              <span class="text-xs text-zinc-400">/ 100</span>
            </div>
          </div>
        </div>

        <!-- Métricas em linguagem leiga -->
        <div class="space-y-4">
          {[
            { label: 'Velocidade de abertura', value: '< 1.2s', status: 'Excelente', color: 'text-emerald-400', bar: 95 },
            { label: 'Estabilidade da página', value: 'Estável', status: 'Excelente', color: 'text-emerald-400', bar: 98 },
            { label: 'Resposta ao toque', value: '< 50ms', status: 'Excelente', color: 'text-emerald-400', bar: 90 },
          ].map(m => (
            <div>
              <div class="flex justify-between items-center mb-1.5">
                <span class="text-sm text-zinc-300">{m.label}</span>
                <div class="flex items-center gap-2">
                  <span class="text-xs font-mono text-zinc-500">{m.value}</span>
                  <span class={`text-xs font-medium ${m.color}`}>{m.status}</span>
                </div>
              </div>
              <div class="h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                <div class="h-full bg-[#6366F1] rounded-full shadow-[0_0_8px_rgba(99,102,241,0.5)]" style={`width:${m.bar}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 pt-5 border-t border-zinc-800/60 text-center">
          <p class="text-sm text-zinc-400">
            <span class="text-emerald-400 font-bold font-['Outfit']">100%</span> dos visitantes abrem sua página na primeira tentativa
          </p>
        </div>
      </div>
    </div>

  </div>
</section>
