---
import Button from '../Button.astro';
---

<section class="relative pt-32 pb-16 flex flex-col items-center text-center overflow-hidden">
  <!-- Container centralizado -->
  <div class="max-w-4xl mx-auto text-center px-6">
    <!-- Badge minimalista -->
    <div class="inline-flex items-center gap-2 text-xs text-emerald-500 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="font-medium">Nota Máxima no Google Pagespeed</span>
    </div>

    <!-- H1 -->
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-6 leading-[1.15]">
      O Site Que Transforma Seus Anúncios em <span class="text-[#6366F1]">Clientes no WhatsApp</span>.
    </h1>

    <!-- Subtítulo -->
    <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mt-4 leading-relaxed">
      Páginas ultra-rápidas que não deixam o cliente do seu anúncio ir embora. Substituímos seu site lento por uma estrutura focada em uma única coisa: fazer seu telefone tocar.
    </p>

    <!-- Trust Signal - Métrica de Impacto (entre subtítulo e CTA) -->
    <div class="mt-8 flex items-center justify-center gap-4 bg-zinc-900/60 border border-zinc-800 rounded-md py-3 px-5 max-w-xl mx-auto">
      <span class="font-mono text-2xl font-bold text-emerald-400">5 em 10</span>
      <span class="text-sm text-zinc-300">clientes são perdidos por sites lentos antes da página abrir. <span class="text-zinc-500 text-xs ml-2">(Fonte: Google)</span></span>
    </div>

    <!-- Botão CTA High-Ticket -->
    <div class="mt-10">
      <Button variant="primary" class="text-base px-10 py-4">Solicitar Análise de Conversão</Button>
    </div>
    
    <!-- Comparativo de NEGÓCIOS (Cliques vs Leads) -->
    <div class="max-w-lg mx-auto mt-12 w-full space-y-4">
      <!-- Barra 1: Cliques Perdidos -->
      <div class="text-left">
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm font-medium text-zinc-500">Cliques perdidos no site antigo</span>
          <span class="text-xs text-red-400 font-medium">Dinheiro indo embora</span>
        </div>
        <div class="h-3 bg-zinc-800/50 rounded-sm overflow-hidden">
          <div class="h-full w-[75%] bg-zinc-700 rounded-sm"></div>
        </div>
      </div>
      
      <!-- Barra 2: Leads Capturados -->
      <div class="text-left">
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm font-bold text-white">Leads capturados com a Anúncio e Site</span>
          <span class="text-xs text-emerald-500 font-medium">Clientes ligando pra você</span>
        </div>
        <div class="h-3 bg-zinc-800/50 rounded-sm overflow-hidden">
          <div class="h-full w-full bg-[#6366F1] rounded-sm shadow-[0_0_16px_rgba(99,102,241,0.5)]"></div>
        </div>
      </div>
    </div>
  </div>
</section>