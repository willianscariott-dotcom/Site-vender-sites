---
interface Tier {
  name: string;
  price: string;
  priceNote: string;
  description: string;
  features: string[];
  highlighted?: boolean;
  cta: string;
}

const tiers: Tier[] = [
  {
    name: 'Plano Essencial',
    price: 'R$ 89',
    priceNote: '/mês · fidelidade de 12 meses',
    description: 'Para quem quer parar de perder cliques e começar a converter agora.',
    features: [
      '1 Landing Page de Alta Velocidade',
      'Hospedagem Premium Inclusa',
      'Botão de WhatsApp Fixo',
      'Certificado SSL e Segurança',
    ],
    highlighted: false,
    cta: 'Começar com o Essencial',
  },
  {
    name: 'Plano Performance',
    price: 'A partir de R$ 297',
    priceNote: '/mês · para campanhas de alta escala',
    description: 'Para quem já anuncia e quer extrair o máximo de cada real investido.',
    features: [
      'Tudo do Plano Essencial',
      'Múltiplas Landing Pages (Testes A/B)',
      'Formulário de Qualificação de Leads',
      'Integração com Pixels do Meta e Google',
      'Suporte Prioritário para Alterações',
    ],
    highlighted: true,
    cta: 'Começar com o Performance',
  },
];
---

<section id="planos" class="w-full max-w-5xl mx-auto px-6 py-32 bg-transparent">
  <!-- Cabeçalho da seção -->
  <div class="text-center mb-20">
    <p class="font-mono text-xs text-[#6366F1] tracking-[0.2em] uppercase mb-4">Investimento</p>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white font-['Outfit'] mb-5">
      Planos
    </h2>
    <p class="text-zinc-400 max-w-xl mx-auto text-lg leading-relaxed">
      Você foca nos anúncios. A gente cuida da página.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full items-stretch">
    {tiers.map((tier) => (
      <div class:list={[
        'relative flex flex-col rounded-3xl p-px overflow-hidden transition-all duration-500',
        tier.highlighted
          ? 'shadow-[0_0_60px_rgba(99,102,241,0.15)]'
          : 'shadow-2xl'
      ]}>
        <!-- Gradient border wrapper -->
        <div class:list={[
          'absolute inset-0 rounded-3xl',
          tier.highlighted
            ? 'bg-gradient-to-br from-[#6366F1]/60 via-indigo-500/20 to-transparent'
            : 'bg-gradient-to-br from-zinc-700/40 via-zinc-800/20 to-transparent'
        ]}></div>

        <!-- Card body -->
        <div class:list={[
          'relative flex flex-col flex-1 rounded-3xl p-8 lg:p-10',
          tier.highlighted
            ? 'bg-[#0f0f14]'
            : 'bg-[#111115]/80 backdrop-blur-xl'
        ]}>

          <!-- Badge diagonal para plano destaque -->
          {tier.highlighted && (
            <div class="absolute top-6 right-6 bg-[#6366F1]/10 border border-[#6366F1]/30 text-[#6366F1] text-[10px] font-mono uppercase tracking-widest px-3 py-1 rounded-full">
              Mais Escolhido
            </div>
          )}

          <!-- Nome do plano -->
          <p class="font-mono text-xs text-zinc-500 tracking-[0.15em] uppercase mb-6">{tier.name}</p>

          <!-- Preço -->
          <div class="mb-2">
            <span class="text-4xl font-bold text-white font-['Outfit'] tracking-tight">{tier.price}</span>
          </div>
          <p class="text-sm text-zinc-500 mb-4">{tier.priceNote}</p>

          <!-- Descrição -->
          <p class="text-zinc-400 text-sm leading-relaxed mb-8 border-b border-zinc-800/60 pb-8">
            {tier.description}
          </p>

          <!-- Features -->
          <ul class="space-y-4 mb-10 flex-1">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-zinc-300">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[#6366F1]" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-opacity="0.2" stroke-width="1"/>
                  <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <button
            onclick={`openIntakeForm('${tier.name}', '${tier.price}')`}
            class:list={[
              'w-full py-4 px-6 rounded-2xl font-semibold text-sm transition-all duration-300 cursor-pointer font-["Outfit"]',
              tier.highlighted
                ? 'bg-[#6366F1] text-white hover:bg-indigo-500 hover:shadow-[0_0_30px_rgba(99,102,241,0.4)] active:scale-[0.98]'
                : 'bg-zinc-800/60 text-zinc-200 border border-zinc-700/60 hover:bg-zinc-700/60 hover:text-white hover:border-zinc-600 active:scale-[0.98]'
            ]}
          >
            {tier.cta}
          </button>
        </div>
      </div>
    ))}
  </div>

  <!-- Nota de rodapé -->
  <p class="text-center text-xs text-zinc-600 mt-10">
    Sem taxa de criação. Sem surpresas. Cancele quando quiser de acordo com os termos do pacote.
  </p>
</section>