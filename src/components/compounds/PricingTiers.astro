---
import Button from '../Button.astro';

interface Tier {
  name: string;
  price: string;
  description: string;
  features: string[];
  highlighted?: boolean;
}

const tiers: Tier[] = [
  {
    name: '[ A DEFINIR ]',
    price: '[ A DEFINIR ]',
    description: 'Ideal para pequenas empresas que querem acelerar resultados.',
    features: [
      '1 Landing Page otimizada',
      'Hospedagem Edge Global',
      'SSL Grátis',
      'Suporte por email',
      'Relatório mensal de performance',
    ],
  },
  {
    name: '[ A DEFINIR ]',
    price: '[ A DEFINIR ]',
    description: 'Para médias empresas que precisam de escala.',
    features: [
      '5 Landing Pages',
      'SEO Programático (até 50 páginas)',
      'A/B Testing contínuo',
      'API de integrações',
      'Priority support',
      'CRO evolutivo mensal',
    ],
    highlighted: true,
  },
];
---

<section class="py-20">
  <div class="max-w-container-max mx-auto px-gutter">
    <h2 class="font-headline-h2 text-headline-h2 text-center mb-6">
      Infraestrutura de Alta Performance para o seu <span class="text-[#6366F1]">Crescimento</span>.
    </h2>
    
    <p class="font-body-base text-body-base text-text-secondary text-center max-w-2xl mx-auto mb-16">
      Sem taxa de setup. Sem surprises. Pague mensalmente e tenha sua infraestrutura de conversão sempre otimizada.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {tiers.map((tier) => (
        <div class:list={[
          'relative bg-zinc-950/80 backdrop-blur-[12px] border rounded-lg p-8',
          tier.highlighted ? 'border-[#6366F1]' : 'border-slate-800'
        ]}>
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#6366F1] text-white px-4 py-1 rounded-full text-xs font-technical-mono uppercase">
              Mais Popular
            </div>
          )}
          
          <h3 class="font-headline-h3 text-headline-h3 mb-2">{tier.name}</h3>
          
          <div class="text-3xl font-bold text-white mb-2">{tier.price}</div>
          
          <p class="font-body-sm text-body-sm text-text-secondary mb-6">
            {tier.description}
          </p>
          
          <ul class="space-y-3 mb-8">
            {tier.features.map((feature) => (
              <li class="flex items-center gap-2 font-body-sm text-body-sm text-zinc-300">
                <span class="text-[#6366F1]">✓</span>
                {feature}
              </li>
            ))}
          </ul>
          
          <Button variant={tier.highlighted ? 'primary' : 'secondary'} class="w-full">
            Começar Agora
          </Button>
        </div>
      ))}
    </div>
  </div>
</section>