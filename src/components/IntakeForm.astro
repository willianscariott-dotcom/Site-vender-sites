---
---

<div id="intake-form-container" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeIntakeForm()"></div>

  <!-- Modal -->
  <div id="intake-modal" class="relative w-full sm:max-w-md bg-[#111115] border border-zinc-800/80 rounded-t-3xl sm:rounded-3xl p-7 shadow-2xl translate-y-8 opacity-0 transition-all duration-300">
    <!-- Drag handle (mobile) -->
    <div class="sm:hidden w-10 h-1 bg-zinc-700 rounded-full mx-auto mb-6"></div>

    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <div>
        <div class="flex items-center gap-2.5 mb-1">
          <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="font-mono text-xs text-emerald-500 tracking-widest uppercase">Verificar Disponibilidade</span>
        </div>
        <h3 class="font-['Outfit'] text-xl font-bold text-white">Vamos começar</h3>
        <p id="form-plan-info" class="text-sm text-zinc-400 mt-1">Selecione um plano</p>
      </div>
      <button
        onclick="closeIntakeForm()"
        class="text-zinc-600 hover:text-zinc-300 transition-colors p-1 -mt-1"
        aria-label="Fechar"
      >
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Top accent line -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#6366F1]/40 to-transparent rounded-t-3xl"></div>

    <form id="intake-form" class="space-y-4">
      <div>
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Nome Completo *</label>
        <input
          type="text"
          name="name"
          required
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm"
          placeholder="Seu nome completo"
        />
      </div>

      <div>
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">WhatsApp *</label>
        <input
          type="tel"
          name="whatsapp"
          required
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm"
          placeholder="(00) 00000-0000"
        />
      </div>

      <div>
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">E-mail *</label>
        <input
          type="email"
          name="email"
          required
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm"
          placeholder="seu@email.com"
        />
      </div>

      <div>
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Qual é seu maior desafio hoje? *</label>
        <select
          name="challenge"
          required
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white focus:outline-none focus:border-[#6366F1]/60 transition-all duration-200 text-sm"
        >
          <option value="" disabled selected class="text-zinc-600">Selecione uma opção</option>
          <option value="Site lento">Meu site demora para carregar</option>
          <option value="Cliques sem contato">Tenho cliques nos anúncios, mas poucos contatos</option>
          <option value="Sem estrutura">Ainda não tenho uma estrutura profissional</option>
          <option value="Outro">Outro</option>
        </select>
      </div>

      <div>
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Link do site atual <span class="text-zinc-500 font-normal">(opcional)</span></label>
        <input
          type="url"
          name="website"
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm"
          placeholder="https://seusite.com.br"
        />
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full py-4 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 hover:shadow-[0_0_24px_rgba(99,102,241,0.4)] transition-all duration-300 active:scale-[0.98] mt-2 font-['Outfit'] text-sm"
      >
        Verificar Disponibilidade
      </button>
    </form>
  </div>
</div>

<script>
  const formContainer = document.getElementById('intake-form-container');
  const modal = document.getElementById('intake-modal');
  const form = document.getElementById('intake-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formPlanInfo = document.getElementById('form-plan-info');

  (window as any).openIntakeForm = function(planName: string, planPrice: string) {
    if (formContainer && modal) {
      formContainer.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Animate in
      requestAnimationFrame(() => {
        modal.classList.remove('translate-y-8', 'opacity-0');
        modal.classList.add('translate-y-0', 'opacity-100');
      });
    }
    if (formPlanInfo) {
      formPlanInfo.textContent = `${planName} — ${planPrice}`;
    }
    const existingPlanInput = form.querySelector('input[name="plan"]');
    if (existingPlanInput) existingPlanInput.remove();
    const planInput = document.createElement('input');
    planInput.type = 'hidden';
    planInput.name = 'plan';
    planInput.value = planName;
    form.appendChild(planInput);
  };

  (window as any).closeIntakeForm = function() {
    if (formContainer && modal) {
      modal.classList.add('translate-y-8', 'opacity-0');
      modal.classList.remove('translate-y-0', 'opacity-100');
      setTimeout(() => {
        formContainer.classList.add('hidden');
        document.body.style.overflow = '';
        form.reset();
        submitBtn.textContent = 'Verificar Disponibilidade';
        submitBtn.disabled = false;
      }, 300);
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const planName = data.plan as string;

    submitBtn.textContent = 'Enviando...';
    submitBtn.disabled = true;

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          access_key: 'YOUR_ACCESS_KEY_HERE',
          to: 'willianscariott@gmail.com',
          subject: `🔥 NOVO LEAD — Anúncio e Site: ${planName}`,
          from_name: 'Site Anúncio e Site',
          name: data.name,
          email: data.email,
          whatsapp: data.whatsapp,
          website: data.website || 'Não informado',
          challenge: data.challenge,
          plan: planName,
        }),
      });

      if (response.ok) {
        // Success state
        submitBtn.textContent = '✓ Enviado! Redirecionando...';
        submitBtn.classList.replace('bg-[#6366F1]', 'bg-emerald-600');
        setTimeout(() => {
          const name = encodeURIComponent(data.name as string);
          const planEncoded = encodeURIComponent(planName);
          const message = `Olá! Meu nome é ${data.name} e preenchi o formulário no site. Gostaria de avançar com o ${planEncoded} para o meu negócio.`;
          window.location.href = `https://wa.me/51999402810?text=${encodeURIComponent(message)}`;
        }, 800);
      } else {
        submitBtn.textContent = 'Tentar novamente';
        submitBtn.disabled = false;
      }
    } catch {
      submitBtn.textContent = 'Erro — tente novamente';
      submitBtn.disabled = false;
    }
  });
</script>