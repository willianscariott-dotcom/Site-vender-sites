---
interface Props {
  variant?: 'primary' | 'secondary' | 'cta';
  href?: string;
  class?: string;
}

const { variant = 'primary', href, class: className = '' } = Astro.props;

const baseStyles = 'font-technical-mono text-technical-mono px-8 py-4 rounded-lg cursor-pointer inline-flex items-center justify-center gap-2';

const variants = {
  primary: 'bg-[#6366F1] text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all duration-150 active:scale-[0.98]',
  secondary: 'bg-zinc-950/80 backdrop-blur-[12px] border border-slate-800 text-zinc-100 hover:bg-slate-800/50 hover:border-slate-700 transition-all duration-150',
  cta: 'bg-[#6366F1] text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all duration-150',
};

const styles = variants[variant];
---

{href ? (
  <a href={href} class:list={[baseStyles, styles, className]}>
    <slot />
  </a>
) : (
  <button class:list={[baseStyles, styles, className]}>
    <slot />
  </button>
)}