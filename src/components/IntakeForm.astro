---

---

<div id="intake-form-container" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeIntakeForm()"></div>

  <div id="intake-modal" class="relative w-full sm:max-w-md bg-[#111115] border border-zinc-800/80 rounded-t-3xl sm:rounded-3xl p-7 shadow-2xl translate-y-8 opacity-0 transition-all duration-300">
    <div class="sm:hidden w-10 h-1 bg-zinc-700 rounded-full mx-auto mb-6"></div>

    <div class="flex items-start justify-between mb-6">
      <div>
        <div class="flex items-center gap-2.5 mb-1">
          <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="font-mono text-xs text-emerald-500 tracking-widest uppercase">Verificar Disponibilidade</span>
        </div>
        <h3 class="font-['Outfit'] text-xl font-bold text-white">Vamos começar</h3>
        <p id="form-plan-info" class="text-sm text-zinc-400 mt-1">Selecione um plano</p>
        <p id="step-indicator" class="text-xs text-zinc-500 mt-2">Passo 1 de 5</p>
      </div>
      <button onclick="closeIntakeForm()" class="text-zinc-600 hover:text-zinc-300 transition-colors p-1 -mt-1" aria-label="Fechar">
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#6366F1]/40 to-transparent rounded-t-3xl"></div>

    <form id="intake-form" class="space-y-4">
      <input type="hidden" name="plan" />

      <!-- Step 1: Nome -->
      <div class="step-content" data-step="1">
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Qual é o seu nome completo?</label>
        <input type="text" name="name" required class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm" placeholder="Seu nome" />
        <button type="button" onclick="nextStep(1)" class="w-full mt-4 py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 transition-all duration-300 text-sm">Avançar</button>
      </div>

      <!-- Step 2: WhatsApp -->
      <div class="step-content hidden" data-step="2">
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Qual é o seu WhatsApp?</label>
        <input type="tel" name="whatsapp" required class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm" placeholder="(00) 00000-0000" />
        <button type="button" onclick="nextStep(2)" class="w-full mt-4 py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 transition-all duration-300 text-sm">Avançar</button>
      </div>

      <!-- Step 3: E-mail -->
      <div class="step-content hidden" data-step="3">
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Qual é o seu e-mail?</label>
        <input type="email" name="email" required class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm" placeholder="seu@email.com" />
        <button type="button" onclick="nextStep(3)" class="w-full mt-4 py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 transition-all duration-300 text-sm">Avançar</button>
      </div>

      <!-- Step 4: Desafio -->
      <div class="step-content hidden" data-step="4">
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Qual é o seu maior desafio hoje?</label>
        <select name="challenge" required class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white focus:outline-none focus:border-[#6366F1]/60 transition-all duration-200 text-sm">
          <option value="" disabled selected class="text-zinc-600">Selecione uma opção</option>
          <option value="Site lento">Meu site demora para carregar</option>
          <option value="Cliques sem contato">Tenho cliques nos anúncios, mas poucos contatos</option>
          <option value="Sem estrutura">Ainda não tenho uma estrutura profissional</option>
          <option value="Outro">Outro</option>
        </select>
        <button type="button" onclick="nextStep(4)" class="w-full mt-4 py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 transition-all duration-300 text-sm">Avançar</button>
      </div>

      <!-- Step 5: Site atual (opcional) -->
      <div class="step-content hidden" data-step="5">
        <label class="block text-sm text-zinc-300 mb-1.5 font-medium">Tem um site atual? <span class="text-zinc-500 font-normal">(opcional)</span></label>
        <input type="url" name="website" class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:border-[#6366F1]/60 focus:bg-zinc-900 transition-all duration-200 text-sm" placeholder="https://seusite.com.br" />
        <button type="button" onclick="nextStep(5)" class="w-full mt-4 py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-2xl hover:bg-indigo-500 transition-all duration-300 text-sm">Finalizar</button>
      </div>

      <!-- Step 6: WhatsApp opt-in -->
      <div class="step-content hidden" data-step="6">
        <div class="text-center py-4">
          <div class="w-16 h-16 bg-[#6366F1]/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.195.194 1.662.111.576-.103 1.778-1.04 2.223-2.046.222-.502.372-1.048.372-1.506 0-.448-.127-.846-.371-1.164l-.001-.001zm-3.21 8.27c-.297.149-1.758.867-2.03.967-.273.099-.471.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.195.194 1.662.111.576-.103 1.778-1.04 2.223-2.046.222-.502.372-1.048.372-1.506 0-.448-.127-.846-.371-1.164l-.001-.001z"/>
            </svg>
          </div>
          <h4 class="text-lg font-bold text-white mb-2">Quer agilidade?</h4>
          <p class="text-sm text-zinc-400 mb-6">Posso te chamar agora no WhatsApp para finalizar tudo mais rápido.</p>
          <div class="flex flex-col gap-3">
            <button type="button" onclick="submitToWhatsApp()" class="w-full py-3.5 px-6 bg-emerald-600 text-white font-semibold rounded-2xl hover:bg-emerald-500 hover:shadow-[0_0_20px_rgba(22,163,74,0.4)] transition-all duration-300 text-sm flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.195.194 1.662.111.576-.103 1.778-1.04 2.223-2.046.222-.502.372-1.048.372-1.506 0-.448-.127-.846-.371-1.164l-.001-.001zm-3.21 8.27c-.297.149-1.758.867-2.03.967-.273.099-.471.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.195.194 1.662.111.576-.103 1.778-1.04 2.223-2.046.222-.502.372-1.048.372-1.506 0-.448-.127-.846-.371-1.164l-.001-.001z"/></svg>
              Sim, me chama agora!
            </button>
            <button type="button" onclick="submitForm()" class="w-full py-3.5 px-6 bg-zinc-800 text-white font-semibold rounded-2xl hover:bg-zinc-700 transition-all duration-300 text-sm">
              Não, prefiro receber por e-mail
            </button>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  const formContainer = document.getElementById('intake-form-container');
  const modal = document.getElementById('intake-modal');
  const form = document.getElementById('intake-form') as HTMLFormElement;
  const stepIndicator = document.getElementById('step-indicator');

  (window as any).openIntakeForm = function(planName: string, planPrice: string) {
    if (formContainer && modal) {
      formContainer.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        modal.classList.remove('translate-y-8', 'opacity-0');
        modal.classList.add('translate-y-0', 'opacity-100');
      });
    }
    const formPlanInfo = document.getElementById('form-plan-info');
    if (formPlanInfo) formPlanInfo.textContent = `${planName} — ${planPrice}`;
    const planInput = form.querySelector('input[name="plan"]') as HTMLInputElement;
    if (planInput) planInput.value = planName;
    resetToStep1();
  };

  (window as any).closeIntakeForm = function() {
    if (formContainer && modal) {
      modal.classList.add('translate-y-8', 'opacity-0');
      modal.classList.remove('translate-y-0', 'opacity-100');
      setTimeout(() => {
        formContainer.classList.add('hidden');
        document.body.style.overflow = '';
        form.reset();
        resetToStep1();
      }, 300);
    }
  };

  function resetToStep1() {
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.querySelector('.step-content[data-step="1"]')?.classList.remove('hidden');
    if (stepIndicator) stepIndicator.textContent = 'Passo 1 de 5';
  }

  (window as any).nextStep = function(currentStep: number) {
    const currentEl = document.querySelector(`.step-content[data-step="${currentStep}"]`) as HTMLElement;
    const input = currentEl?.querySelector('input, select') as HTMLInputElement;
    
    if (input && !input.checkValidity()) {
      input.reportValidity();
      return;
    }

    if (currentStep === 5) {
      showStep(6);
      if (stepIndicator) stepIndicator.textContent = 'Quase lá!';
    } else {
      showStep(currentStep + 1);
      if (stepIndicator) stepIndicator.textContent = `Passo ${currentStep + 1} de 5`;
    }
  };

  function showStep(step: number) {
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.querySelector(`.step-content[data-step="${step}"]`)?.classList.remove('hidden');
  }

  (window as any).submitToWhatsApp = async function() {
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const planName = data.plan as string;

    const message = `Olá! Me chamo ${data.name}. Escolhi o plano ${planName}.%0A%0AMeu WhatsApp: ${data.whatsapp}%0AEmail: ${data.email}%0ADesafio: ${data.challenge}%0A${data.website ? 'Site: ' + data.website : ''}`;
    
    window.location.href = `https://wa.me/5551999402810?text=${message}`;
  };

  (window as any).submitForm = async function() {
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const planName = data.plan as string;

    try {
      await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          access_key: 'YOUR_ACCESS_KEY_HERE',
          to: 'willianscariott@gmail.com',
          subject: `🔥 NOVO LEAD — Anúncio e Site: ${planName}`,
          from_name: 'Site Anúncio e Site',
          name: data.name,
          email: data.email,
          whatsapp: data.whatsapp,
          website: data.website || 'Não informado',
          challenge: data.challenge,
          plan: planName,
        }),
      });

      const btn = document.querySelector('button[onclick="submitForm()"]') as HTMLButtonElement;
      btn.textContent = '✓ Enviado! Obrigado.';
      btn.classList.replace('bg-zinc-800', 'bg-emerald-600');
      setTimeout(() => closeIntakeForm(), 2000);
    } catch {
      alert('Erro ao enviar. Tente novamente.');
    }
  };
</script>