---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/compounds/HeroV5E.astro';
import ProblemAgitation from '../components/compounds/ProblemAgitation.astro';
import SolutionFeatures from '../components/compounds/SolutionFeatures.astro';
import HowItWorks from '../components/compounds/HowItWorks.astro';
import PricingTiers from '../components/compounds/PricingTiers.astro';
import FaqSection from '../components/compounds/FaqSection.astro';
import Footer from '../components/Footer.astro';
import IntakeForm from '../components/IntakeForm.astro';
import TrustSignals from '../components/compounds/TrustSignals.astro';
---

<Layout title="Anúncio e Site | Landing Pages Ultrarrápidas">
  <!-- Spotlight superior focado -->
  <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#6366F1]/5 blur-[160px] rounded-full pointer-events-none -z-10"></div>
  
  <Header />
  
  <!-- Masked Borders - Gaiola de Engenharia -->
  <div class="fixed inset-0 pointer-events-none -z-10">
    <div class="absolute top-[200px] left-0 right-0 h-px bg-zinc-900/50"></div>
    <div class="absolute top-[450px] left-0 right-0 h-px bg-zinc-900/50"></div>
    <div class="absolute top-[700px] left-0 right-0 h-px bg-zinc-900/50"></div>
    <div class="absolute top-[950px] left-0 right-0 h-px bg-zinc-900/50"></div>
  </div>
  
  <main class="relative bg-transparent">
    <div class="max-w-container-max mx-auto flex flex-col gap-0">
      <Hero />
      <div class="border-t border-zinc-900/50"></div>
      <ProblemAgitation />
      <div class="border-t border-zinc-900/50"></div>
      <SolutionFeatures />
      <div class="border-t border-zinc-900/50"></div>
      <HowItWorks />
      <div class="border-t border-zinc-900/50"></div>
      <TrustSignals />
      <div class="border-t border-zinc-900/50"></div>
      <PricingTiers />
      <div class="border-t border-zinc-900/50"></div>
      <FaqSection />
    </div>
  </main>
  
  <Footer />
  
  <IntakeForm />
</Layout>