---
---

<div id="intake-form-container" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeIntakeForm()"></div>
  
  <div class="relative w-full max-w-md bg-zinc-950/95 backdrop-blur-xl border border-zinc-800 rounded-md p-6 shadow-2xl">
    <button onclick="closeIntakeForm()" class="absolute top-4 right-4 text-zinc-500 hover:text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <h3 class="text-xl font-bold text-white mb-2">Verificar Disponibilidade</h3>
    <p id="form-plan-info" class="text-sm text-zinc-400 mb-6">Selecione um plano</p>
    
    <form id="intake-form" class="space-y-4">
      <div>
        <label class="block text-sm text-zinc-400 mb-1">Nome Completo *</label>
        <input 
          type="text" 
          name="name" 
          required 
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-md text-white placeholder-zinc-500 focus:outline-none focus:border-[#6366F1]"
          placeholder="Seu nome completo"
        />
      </div>
      
      <div>
        <label class="block text-sm text-zinc-400 mb-1">WhatsApp *</label>
        <input 
          type="tel" 
          name="whatsapp" 
          required 
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-md text-white placeholder-zinc-500 focus:outline-none focus:border-[#6366F1]"
          placeholder="(00) 00000-0000"
        />
      </div>
      
      <div>
        <label class="block text-sm text-zinc-400 mb-1">E-mail Profissional *</label>
        <input 
          type="email" 
          name="email" 
          required 
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-md text-white placeholder-zinc-500 focus:outline-none focus:border-[#6366F1]"
          placeholder="seu@email.com"
        />
      </div>
      
      <div>
        <label class="block text-sm text-zinc-400 mb-1">Link do Site Atual</label>
        <input 
          type="url" 
          name="website" 
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-md text-white placeholder-zinc-500 focus:outline-none focus:border-[#6366F1]"
          placeholder="https://seusite.com.br"
        />
        <p class="text-xs text-zinc-500 mt-1">Deixe em branco se ainda não tiver</p>
      </div>
      
      <div>
        <label class="block text-sm text-zinc-400 mb-1">Qual é o seu maior desafio hoje? *</label>
        <select 
          name="challenge" 
          required 
          class="w-full px-4 py-3 bg-zinc-900/60 border border-zinc-800 rounded-md text-white focus:outline-none focus:border-[#6366F1]"
        >
          <option value="" disabled selected>Selecione uma opção</option>
          <option value="Meu site atual demora para carregar">Meu site atual demora para carregar</option>
          <option value="Meus anúncios recebem cliques mas não geram contatos">Meus anúncios recebem cliques mas não geram contatos</option>
          <option value="Ainda não tenho uma estrutura profissional">Ainda não tenho uma estrutura profissional</option>
          <option value="Outro">Outro</option>
        </select>
      </div>
      
      <button 
        type="submit" 
        id="submit-btn"
        class="w-full py-3 px-6 bg-[#6366F1] text-white font-semibold rounded-md hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all"
      >
        Verificar Disponibilidade
      </button>
    </form>
  </div>
</div>

<script>
  const formContainer = document.getElementById('intake-form-container');
  const form = document.getElementById('intake-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formPlanInfo = document.getElementById('form-plan-info');
  
  (window as any).openIntakeForm = function(planName: string, planPrice: string) {
    if (formContainer) {
      formContainer.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    if (formPlanInfo) {
      formPlanInfo.textContent = `${planName} - ${planPrice}`;
    }
    const existingPlanInput = form.querySelector('input[name="plan"]');
    if (existingPlanInput) existingPlanInput.remove();
    const planInput = document.createElement('input');
    planInput.type = 'hidden';
    planInput.name = 'plan';
    planInput.value = planName;
    form.appendChild(planInput);
  };
  
  (window as any).closeIntakeForm = function() {
    if (formContainer) {
      formContainer.classList.add('hidden');
      document.body.style.overflow = '';
    }
    const planInput = form.querySelector('input[name="plan"]');
    if (planInput) planInput.remove();
    form.reset();
    submitBtn.textContent = 'Verificar Disponibilidade';
    submitBtn.disabled = false;
  };
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const planName = data.plan as string;
    
    submitBtn.textContent = 'Processando...';
    submitBtn.disabled = true;
    
    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          access_key: 'YOUR_ACCESS_KEY_HERE',
          to: 'willianscariott@gmail.com',
          subject: `🔥 NOVO LEAD - Anúncio e Site: ${planName}`,
          from_name: 'Site Anúncio e Site',
          name: data.name,
          email: data.email,
          whatsapp: data.whatsapp,
          website: data.website || 'Não informado',
          challenge: data.challenge,
          plan: planName,
        }),
      });
      
      if (response.ok) {
        const name = encodeURIComponent(data.name as string);
        const planEncoded = encodeURIComponent(planName);
        const message = `Olá! Meu nome é ${name} e preenchi o formulário no site. Gostaria de avançar com o ${planEncoded} para o meu negócio.`;
        window.location.href = `https://wa.me/51999402810?text=${message}`;
      } else {
        submitBtn.textContent = 'Tentar novamente';
        submitBtn.disabled = false;
        alert('Algo deu errado. Tente novamente.');
      }
    } catch (error) {
      submitBtn.textContent = 'Tentar novamente';
      submitBtn.disabled = false;
      alert('Erro ao enviar. Por favor, tente novamente.');
    }
  });
</script>