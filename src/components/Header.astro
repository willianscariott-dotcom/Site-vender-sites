---
---

<header id="site-header" class="fixed top-0 w-full z-50 transition-all duration-300">
  <!-- Glassmorphism background (opacity controlled by JS on scroll) -->
  <div id="header-bg" class="absolute inset-0 bg-[#0a0a0c]/0 backdrop-blur-0 border-b border-transparent transition-all duration-500"></div>

  <div class="relative max-w-screen-xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-['Outfit'] text-lg font-bold tracking-tight shrink-0">
      <span class="text-white">Anúncio</span><span class="text-[#6366F1]">e Site</span>
    </a>

    <!-- Nav âncoras (desktop) -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#planos" class="text-sm text-zinc-400 hover:text-white transition-colors duration-200">Planos</a>
      <a href="#duvidas" class="text-sm text-zinc-400 hover:text-white transition-colors duration-200">Dúvidas</a>
    </nav>

    <!-- CTA -->
    <a
      href="#planos"
      class="hidden md:inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 bg-[#6366F1] text-white rounded-xl hover:bg-indigo-500 hover:shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all duration-300 active:scale-[0.97]"
    >
      Ver Planos
      <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Mobile CTA -->
    <a
      href="#planos"
      class="md:hidden text-sm font-semibold px-4 py-2 bg-[#6366F1] text-white rounded-lg"
    >
      Ver Planos
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const headerBg = document.getElementById('header-bg');

  function updateHeader() {
    if (window.scrollY > 40) {
      headerBg?.classList.remove('bg-[#0a0a0c]/0', 'backdrop-blur-0', 'border-transparent');
      headerBg?.classList.add('bg-[#0a0a0c]/90', 'backdrop-blur-xl', 'border-zinc-800/60');
    } else {
      headerBg?.classList.add('bg-[#0a0a0c]/0', 'backdrop-blur-0', 'border-transparent');
      headerBg?.classList.remove('bg-[#0a0a0c]/90', 'backdrop-blur-xl', 'border-zinc-800/60');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>