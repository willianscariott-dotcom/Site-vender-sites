---
const currentYear = new Date().getFullYear();

const mainLinks = [
  { label: 'Serviços', href: '#' },
  { label: 'Cases', href: '#' },
  { label: 'Blog', href: '#' },
  { label: 'Contato', href: '#' },
];

const nicheLinks = [
  { label: 'Landing Pages para Akademy', href: '#' },
  { label: 'Landing Pages para E-commerce', href: '#' },
  { label: 'Landing Pages para SaaS', href: '#' },
];

const legalLinks = [
  { label: 'Política de Privacidade', href: '#' },
  { label: 'Termos de Serviço', href: '#' },
];
---

<footer class="w-full py-16 border-t border-zinc-900 bg-zinc-950 border-zinc-900 bg-[radial-gradient(#18181b_1px,transparent_1px)] [background-size:20px_20px]">
  <div class="max-w-screen-2xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div>
        <div class="font-inter text-lg font-extrabold tracking-[-0.03em] mb-4">
          <span class="text-text-primary">Anúncio</span><span class="text-[#6366F1]">e Site</span>
        </div>
        <p class="font-body-sm text-body-sm text-zinc-500">
          Páginas ultrarrápidas que transformam cliques em clientes.
        </p>
      </div>
      
      <div>
        <h4 class="font-inter font-bold text-sm text-text-primary mb-4">Navegação</h4>
        <ul class="space-y-2">
          {mainLinks.map((link) => (
            <li>
              <a class="font-body-sm text-body-sm text-zinc-500 hover:text-zinc-100 transition-colors duration-150" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="font-inter font-bold text-sm text-text-primary mb-4">Soluções por Nicho</h4>
        <ul class="space-y-2">
          {nicheLinks.map((link) => (
            <li>
              <a class="font-body-sm text-body-sm text-zinc-500 hover:text-zinc-100 transition-colors duration-150" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="font-inter font-bold text-sm text-text-primary mb-4">Legal</h4>
        <ul class="space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a class="font-body-sm text-body-sm text-zinc-500 hover:text-zinc-100 transition-colors duration-150" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-zinc-900">
      <p class="font-inter text-xs text-zinc-500 text-center">
        © {currentYear} <span class="text-text-primary">Anúncio</span><span class="text-[#6366F1]">e Site</span> — Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>