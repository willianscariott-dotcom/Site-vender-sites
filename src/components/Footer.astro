---
const links = [
  { label: 'DOCUMENTATION', href: '#' },
  { label: 'CHANGELOG', href: '#' },
  { label: 'SYSTEM_STATUS', href: '#' },
  { label: 'SECURITY', href: '#' },
];
---

<footer class="w-full py-12 border-t border-zinc-900 bg-zinc-950 border-zinc-900 bg-[radial-gradient(#18181b_1px,transparent_1px)] [background-size:20px_20px]">
  <div class="max-w-screen-2xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 items-center shadow-none cursor-crosshair">
    <div class="font-mono text-[10px] tracking-widest uppercase text-indigo-500 hover:text-zinc-100 transition-colors duration-150">
      © 2024 LPaaS.CORE // PROTOCOL_V1.0 — ALL RIGHTS RESERVED
    </div>
    
    <div class="flex gap-6 font-mono text-[10px] tracking-widest uppercase text-zinc-600 md:justify-end">
      {links.map((link) => (
        <a class="hover:text-zinc-100 transition-colors duration-150" href={link.href}>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>