---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/compounds/Hero.astro';
import ProblemAgitation from '../components/compounds/ProblemAgitation.astro';
import SolutionFeatures from '../components/compounds/SolutionFeatures.astro';
import HowItWorks from '../components/compounds/HowItWorks.astro';
import PricingTiers from '../components/compounds/PricingTiers.astro';
import FaqSection from '../components/compounds/FaqSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Anúncio e Site | Landing Pages Ultrarrápidas">
  <!-- Spotlight superior focado -->
  <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#6366F1]/5 blur-[160px] rounded-full pointer-events-none -z-10"></div>
  
  <Header />
  
  <main class="relative bg-zinc-950">
    <div class="max-w-container-max mx-auto flex flex-col gap-24">
      <Hero />
      <ProblemAgitation />
      <SolutionFeatures />
      <HowItWorks />
      <PricingTiers />
      <FaqSection />
    </div>
  </main>
  
  <Footer />
</Layout>