---
interface Step {
  number: string;
  title: string;
  description: string;
}

const steps: Step[] = [
  {
    number: '01',
    title: 'A Escolha',
    description: 'Você seleciona o plano de infraestrutura ideal para o momento (e a escala) do seu negócio.',
  },
  {
    number: '02',
    title: 'O Mapa',
    description: 'Você preenche um briefing estratégico de 5 minutos sobre o seu serviço. Sem reuniões intermináveis e sem perda de tempo.',
  },
  {
    number: '03',
    title: 'A Engenharia',
    description: 'Nós assumimos os bastidores e entregamos a sua nova página pronta, testada e 100% otimizada para lucrar com seus anúncios.',
  },
];
---

<section class="w-full max-w-7xl mx-auto px-6 py-24 bg-black">
  <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white text-center mb-12">
    Do zero à sua página no ar, <span class="text-[#6366F1]">sem dor de cabeça</span>.
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full mt-16">
      {steps.map((step, index) => (
        <div class="relative bg-zinc-900/40 backdrop-blur-xl border border-zinc-800 p-8 rounded-md group">
          <div class="absolute -top-3 left-4 font-mono text-3xl font-bold text-[#6366F1]">
            {step.number}
          </div>
          
          <h3 class="text-xl font-bold text-white mt-8 mb-4">{step.title}</h3>
          
          <p class="text-sm text-zinc-400 leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>