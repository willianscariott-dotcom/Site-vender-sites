---
interface FaqItem {
  question: string;
  answer: string;
}

const faqs: FaqItem[] = [
  {
    question: 'Eu já tenho um site institucional, preciso de uma landing page?',
    answer: 'Sim. Um site institucional é como um catálogo cheio de rotas de fuga. Uma landing page é desenhada exclusivamente para receber quem clicou no seu anúncio e fazê-lo entrar em contato.',
  },
  {
    question: 'Eu preciso pagar hospedagem ou domínio à parte?',
    answer: 'A hospedagem de altíssima velocidade e a segurança já estão inclusas na sua assinatura. Você só precisa ter o seu domínio.',
  },
  {
    question: 'E se eu quiser cancelar?',
    answer: 'Nós não queremos prender você. O cancelamento pode ser solicitado a qualquer momento de acordo com os termos do seu pacote.',
  },
];
---

<section class="py-20">
  <div class="max-w-container-max mx-auto px-gutter">
    <h2 class="font-headline-h2 text-headline-h2 text-center mb-6">
      Perguntas <span class="text-[#6366F1]">Frequentes</span>
    </h2>
    
    <p class="font-body-base text-body-base text-text-secondary text-center max-w-2xl mx-auto mb-16">
      Tire suas dúvidas sobre nossa metodologia e modelos de serviço.
    </p>

    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <details class="group bg-zinc-950/80 backdrop-blur-[12px] border border-slate-800 rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-headline-h3 text-headline-h3 list-none">
            <span>{faq.question}</span>
            <span class="text-[#6366F1] group-open:rotate-180 transition-transform duration-150">▼</span>
          </summary>
          <div class="px-6 pb-6 font-body-sm text-body-sm text-text-secondary">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>