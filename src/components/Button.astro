---
interface Props {
  variant?: 'primary' | 'secondary' | 'cta';
  href?: string;
  class?: string;
}

const { variant = 'primary', href, class: className = '' } = Astro.props;

const baseStyles = 'font-technical-mono text-technical-mono px-6 py-3 rounded-md cursor-pointer inline-flex items-center justify-center gap-2 border border-[#111827]';

const variants = {
  primary: 'bg-[#6366F1] text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] hover:border-indigo-500 transition-all duration-150',
  secondary: 'bg-zinc-900/60 backdrop-blur-sm text-zinc-300 hover:bg-slate-800/50 hover:text-white hover:border-slate-700 transition-all duration-150',
  cta: 'bg-[#6366F1] text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.5)] hover:border-indigo-500 transition-all duration-150',
};

const styles = variants[variant];
---

{href ? (
  <a href={href} class:list={[baseStyles, styles, className]}>
    <slot />
  </a>
) : (
  <button class:list={[baseStyles, styles, className]}>
    <slot />
  </button>
)}