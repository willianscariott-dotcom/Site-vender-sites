---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Planos', href: '#planos' },
  { label: 'Dúvidas', href: '#duvidas' },
  { label: 'WhatsApp', href: 'https://wa.me/51999402810' },
];

const legalLinks = [
  { label: 'Política de Privacidade', href: '#' },
  { label: 'Termos de Serviço', href: '#' },
];
---

<footer class="w-full pt-16 pb-8 border-t border-zinc-900/80 bg-[#0a0a0c]">
  <div class="max-w-screen-xl mx-auto px-6">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10 mb-14">

      <!-- Marca + tagline -->
      <div class="max-w-xs">
        <div class="font-['Outfit'] text-xl font-bold tracking-tight mb-3">
          <span class="text-white">Anúncio</span><span class="text-[#6366F1]">e Site</span>
        </div>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Páginas de alta performance que transformam cliques em contatos no WhatsApp.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-zinc-400 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Divider -->
    <div class="h-px w-full bg-gradient-to-r from-transparent via-zinc-800 to-transparent mb-8"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-zinc-600">
        © {currentYear} <span class="text-zinc-500">Anúncio e Site</span> — Todos os direitos reservados.
      </p>

      <div class="flex gap-6">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>