---
interface Props {
  variant?: 'primary' | 'secondary' | 'cta';
  href?: string;
  class?: string;
}

const { variant = 'primary', href, class: className = '' } = Astro.props;

const baseStyles = 'font-["Outfit"] text-sm font-semibold px-6 py-3 rounded-xl cursor-pointer inline-flex items-center justify-center gap-2 transition-all duration-300 active:scale-[0.97]';

const variants = {
  primary: 'bg-[#6366F1] text-white hover:bg-indigo-500 hover:shadow-[0_0_24px_rgba(99,102,241,0.4)]',
  secondary: 'bg-zinc-900/60 backdrop-blur-sm text-zinc-300 border border-zinc-800 hover:bg-zinc-800/60 hover:text-white hover:border-zinc-700',
  cta: 'bg-[#6366F1] text-white hover:bg-indigo-500 hover:shadow-[0_0_24px_rgba(99,102,241,0.4)]',
};

const arrowIcon = `<svg class="w-3.5 h-3.5 btn-arrow" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const styles = variants[variant];
---

{href ? (
  <a href={href} class:list={[baseStyles, styles, className]} set:html={`<span><slot /></span>` + (variant !== 'secondary' ? arrowIcon : '')}>
    <slot />
    {variant !== 'secondary' && (
      <svg class="w-3.5 h-3.5 btn-arrow" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </a>
) : (
  <button class:list={[baseStyles, styles, className]}>
    <slot />
    {variant !== 'secondary' && (
      <svg class="w-3.5 h-3.5 btn-arrow" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </button>
)}

<style>
  .btn-arrow {
    transition: transform 0.2s ease;
  }
  a:hover .btn-arrow,
  button:hover .btn-arrow {
    transform: translateX(3px);
  }
</style>