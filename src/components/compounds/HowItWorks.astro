---
interface Step {
  number: string;
  title: string;
  description: string;
}

const steps: Step[] = [
  {
    number: '01',
    title: 'A Estrutura',
    description: 'Você escolhe o plano ideal para o momento do seu negócio.',
  },
  {
    number: '02',
    title: 'O Mapa',
    description: 'Você responde a um questionário simples sobre o seu serviço (sem reuniões intermináveis).',
  },
  {
    number: '03',
    title: 'A Engenharia',
    description: 'Nós assumimos os bastidores e entregamos a sua infraestrutura pronta e otimizada para receber seus anúncios.',
  },
];
---

<section class="py-20">
  <div class="max-w-container-max mx-auto px-gutter">
    <h2 class="font-headline-h2 text-headline-h2 text-center mb-12">
      Do zero à sua página no ar, <span class="text-[#6366F1]">sem dor de cabeça</span>.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step, index) => (
        <div class="relative bg-zinc-950/80 backdrop-blur-[12px] border border-slate-800 p-8 rounded-lg group">
          <div class="absolute -top-4 -left-4 w-12 h-12 bg-[#6366F1] rounded-lg flex items-center justify-center font-technical-mono text-technical-metric text-white">
            {step.number}
          </div>
          
          <h3 class="font-headline-h3 text-headline-h3 mt-4 mb-4">{step.title}</h3>
          
          <p class="font-body-sm text-body-sm text-text-secondary">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>