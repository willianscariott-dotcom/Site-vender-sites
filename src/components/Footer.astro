---
const currentYear = new Date().getFullYear();

const links = [
  { label: 'Serviços', href: '#' },
  { label: 'Cases', href: '#' },
  { label: 'Blog', href: '#' },
  { label: 'Contato', href: '#' },
];
---

<footer class="w-full py-12 border-t border-zinc-900 bg-zinc-950 border-zinc-900 bg-[radial-gradient(#18181b_1px,transparent_1px)] [background-size:20px_20px]">
  <div class="max-w-screen-2xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 items-center shadow-none">
    <div class="font-inter text-sm font-extrabold tracking-[-0.03em]">
      <span class="text-text-primary">Anúncio</span><span class="text-[#6366F1]">e Site</span>
      <span class="text-zinc-500 text-xs font-normal tracking-normal ml-2">© {currentYear} — Todos os direitos reservados</span>
    </div>
    
    <div class="flex gap-6 font-inter text-xs text-zinc-500 md:justify-end">
      {links.map((link) => (
        <a class="hover:text-zinc-100 transition-colors duration-150" href={link.href}>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>