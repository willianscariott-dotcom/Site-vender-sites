<section class="py-20">
  <div class="max-w-2xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white text-center mb-4">
      Engenharia de Conversão <span class="text-[#6366F1]">Personalizada</span>
    </h2>
    
    <p class="text-zinc-400 text-center max-w-xl mx-auto mb-12">
      Desenvolvemos infraestruturas exclusivas para empresas que já investem em anúncios e precisam parar de perder dinheiro.
    </p>

    <!-- Card Premium de Aplicação -->
    <div class="relative bg-zinc-900/40 backdrop-blur-xl border border-[#6366F1] rounded-md p-8">
      <!-- Badge Premium -->
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#6366F1] text-white px-4 py-1 rounded-sm text-xs font-mono uppercase">
        Exclusivo
      </div>
      
      <div class="text-center mb-8">
        <h3 class="text-xl font-bold text-white mb-2">Engenharia de Conversão Personalizada</h3>
        <div class="text-4xl font-bold text-white mb-1">Projetos a partir de</div>
        <div class="text-5xl font-bold text-[#6366F1]">R$ 5.000</div>
        <p class="text-sm text-zinc-500 mt-2">
          Investimento único. Infraestrutura proprietária para seu negócio.
        </p>
      </div>
      
      <ul class="space-y-4 mb-8">
        <li class="flex items-start gap-3 text-sm text-zinc-300">
          <span class="text-[#6366F1] mt-0.5">✓</span>
          Landing Page exclusiva em código puro (sem WordPress)
        </li>
        <li class="flex items-start gap-3 text-sm text-zinc-300">
          <span class="text-[#6366F1] mt-0.5">✓</span>
          Otimização máxima para Google e Meta Ads
        </li>
        <li class="flex items-start gap-3 text-sm text-zinc-300">
          <span class="text-[#6366F1] mt-0.5">✓</span>
          Integração completa com WhatsApp e CRM
        </li>
        <li class="flex items-start gap-3 text-sm text-zinc-300">
          <span class="text-[#6366F1] mt-0.5">✓</span>
          Hospedagem premium e segurança incluídas
        </li>
        <li class="flex items-start gap-3 text-sm text-zinc-300">
          <span class="text-[#6366F1] mt-0.5">✓</span>
          Suporte contínuo e evoluções mensais
        </li>
      </ul>
      
      <button class="w-full py-4 px-6 bg-[#6366F1] text-white rounded-md font-mono text-base hover:shadow-[0_0_30px_rgba(99,102,241,0.5)] transition-all duration-150">
        Preencher Formulário de Aplicação
      </button>
      
      <p class="text-xs text-zinc-600 text-center mt-4">
        Processo seletivo. Analisamos seu negócio antes de aceitar.
      </p>
    </div>
  </div>
</section>